{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=BankingAIBotDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Cors": {
    "AllowedOrigin": "http://localhost:3000"
  },
  "Jwt": {
    "Issuer": "BankingAIBotAPI",
    "Audience": "BankingAIBotClient",
    "Key": "YOUR_JWT_SECRET_KEY_HERE_MIN_32_BYTES",
    "ExpirationMinutes": 120
  },
  "OpenAI": {
    "Endpoint": "https://api.openai.com/v1/chat/completions",
    "ApiKey": "YOUR_OPENAI_API_KEY_HERE",
    "Model": "gpt-5.4-mini",
    "Temperature": 0.2,
    "MaxCompletionTokens": 800,
    "PromptVersion": "poc-v1"
  }
}
